# LLM 网关（任意 OpenAI 兼容端点：云端 API 或本地自建均可）
# 讲解生成 / 知识库问答用到。可填 OpenAI / 任意兼容服务 / 本地推理服务。
PLANNER_KEY=your-llm-api-key
PLANNER_BASE_URL=https://your-openai-compatible-endpoint/v1
PLANNER_MODEL=your-model-name
PLANNER_TIMEOUT_SECONDS=60

# 选填：高德地图 key（不填则定位/路线推荐走内置策展知识库，不影响 demo）
AMAP_KEY=

# 实时语音（Step-Audio 2.5 Realtime）的 key 不放这里——
# 写到  ~/.stepfun/credentials  ，形如  STEP_API_KEY=***
# 不配置则自动降级为文本讲解，demo 仍可完整运行。
